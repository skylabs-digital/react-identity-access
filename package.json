{
  "name": "@skylabs-digital/react-identity-access",
  "version": "3.2.2",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "A comprehensive React library for multi-tenancy, authentication, authorization, roles, session management, and settings management",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "tsc --watch & vite build --watch",
    "dev:types": "tsc --watch",
    "dev:example": "yarn dev:types & cd example && yarn dev",
    "link:example": "yarn link && cd example && yarn link @skylabs-digital/react-identity-access",
    "unlink:example": "cd example && yarn unlink @skylabs-digital/react-identity-access && yarn install --force",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "sim": "vitest run --config qa/vitest.config.ts",
    "sim:watch": "vitest --config qa/vitest.config.ts",
    "sim:verbose": "vitest run --config qa/vitest.config.ts --reporter=verbose",
    "qa:agentic": "vitest run --config qa/vitest.config.ts --reporter=verbose",
    "ci": "yarn typecheck && yarn lint && yarn test --coverage && yarn build",
    "prepublishOnly": "yarn build",
    "prepare": "husky",
    "release": "semantic-release",
    "preview": "vite preview",
    "demo": "cd example && yarn dev"
  },
  "keywords": [
    "react",
    "authentication",
    "authorization",
    "multi-tenancy",
    "roles",
    "session-management",
    "feature-flags",
    "settings-management",
    "configuration",
    "typescript",
    "hooks",
    "context"
  ],
  "author": "Fer <fer@skylabs.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skylabs-digital/react-identity-access.git"
  },
  "bugs": {
    "url": "https://github.com/skylabs-digital/react-identity-access/issues"
  },
  "homepage": "https://github.com/skylabs-digital/react-identity-access#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^15.2.10",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.8.0",
    "semantic-release": "^25.0.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "yarn@4.5.3"
}
